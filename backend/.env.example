# =============================================================
# Solvagence Global AI Academy — Backend Environment
# Copy to .env — NEVER commit .env to version control
# =============================================================

NODE_ENV=development
PORT=5000
API_VERSION=v1

# MongoDB
MONGODB_URI=mongodb://localhost:27017/solvagence_academy
# MongoDB Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/solvagence_academy

# JWT
JWT_SECRET=replace_with_min_32_char_random_string_here
JWT_EXPIRE=7d

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://academy.solvagence.com

# Email (SMTP)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
SMTP_PASS=your_api_key
EMAIL_FROM_NAME=Solvagence Global AI Academy
EMAIL_FROM_ADDRESS=academy@solvagence.com
EMAIL_ACADEMY=academy@solvagence.com
EMAIL_LEADERS=leaders@solvagence.com

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
ENROLLMENT_RATE_LIMIT_MAX=5

# VAT
VAT_RATE=0.05
VAT_COUNTRY=AE

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
